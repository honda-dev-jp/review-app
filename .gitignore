# 設定ファイルを隠す
/config/env.php
/config/database.php
/.vscode

# テストフォルダを隠す
/test

# 画像ファイルは除外（ディレクトリのみ管理対象）
/images/thumbnail/*
!/images/thumbnail/.gitkeep
/images/icon/*
!/images/icon/.gitkeep
/images/no_image/*
!/images/no_image/.gitkeep

# Windowsシステムファイル
Thumbs.db

# PHP CS Fixer（コード整形ツール）の設定・キャッシュファイル
.php-cs-fixer.cache
